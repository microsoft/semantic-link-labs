from typing import Optional
from uuid import UUID
from sempy_labs.tom import connect_semantic_model
from sempy_labs.directlake._sources import get_direct_lake_sources
import sempy.fabric as fabric


def direct_lake_manager(dataset: str | UUID, workspace: Optional[str | UUID] = None):

    with connect_semantic_model(dataset=dataset, workspace=workspace) as tom:

        if not tom.is_direct_lake():
            raise ValueError("The provided dataset is not a Direct Lake dataset.")

        sources = get_direct_lake_sources(dataset=dataset, workspace=workspace)

        table_list = []
        for t in tom.model.Tables:
            table_name = t.Name
            p = next(p for p in t.Partitions)
            partition_name = p.Name

            if str(p.Mode) == 'DirectLake':
                expression_name = p.Source.SourceExpression.Name
                entity_name = p.Source.EntityName
                schema_name = p.Source.SchemaName
                table_list.append({
                    "TableName": table_name,
                    "PartitionName": partition_name,
                    "ExpressionName": expression_name,
                    "EntityName": entity_name,
                    "SchemaName": schema_name,
                })

    df = fabric.list_columns(dataset=dataset, workspace=workspace, extended=True)
    df_show = df[df['Table Name', 'Column Name', 'Is Resident', 'Temperature', 'Last Accessed']]